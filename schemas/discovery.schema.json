{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Discovery Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "scan_scope",
    "file_inventory",
    "include_graph",
    "macro_index",
    "libname_index",
    "proc_counts",
    "potential_risks",
    "questions_for_user",
    "assumptions",
    "alignment_score"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "scan_scope": { "type": "string", "minLength": 1 },
    "file_inventory": {
      "type": "array",
      "items": { "type": "object" }
    },
    "include_graph": {
      "type": "array",
      "items": { "type": "object" }
    },
    "macro_index": {
      "type": "array",
      "items": { "type": "object" }
    },
    "libname_index": {
      "type": "array",
      "items": { "type": "object" }
    },
    "proc_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "potential_risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "questions_for_user": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "alignment_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    }
  }
}
