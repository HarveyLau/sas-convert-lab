{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conversion Manifest Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "target_profile",
    "generated_artifacts",
    "source_to_target_trace",
    "known_gaps",
    "questions_for_user",
    "assumptions",
    "alignment_score"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "target_profile": { "type": "string", "minLength": 1 },
    "generated_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_to_target_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "known_gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "questions_for_user": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "alignment_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    }
  }
}
