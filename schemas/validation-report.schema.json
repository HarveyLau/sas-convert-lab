{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Validation Report Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "code_validation",
    "data_validation",
    "intent_validation",
    "release_readiness",
    "questions_for_user",
    "assumptions",
    "alignment_score"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "code_validation": { "type": "object" },
    "data_validation": { "type": "object" },
    "intent_validation": { "type": "object" },
    "release_readiness": {
      "type": "string",
      "enum": ["go", "go-with-risks", "no-go"]
    },
    "questions_for_user": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "alignment_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    }
  }
}
