{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Migration Plan Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "target_profile",
    "waves",
    "dependency_map",
    "effort_estimate",
    "risk_mitigation_actions",
    "questions_for_user",
    "assumptions",
    "alignment_score"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "target_profile": { "type": "string", "minLength": 1 },
    "waves": { "type": "array", "items": { "type": "object" } },
    "dependency_map": { "type": "array", "items": { "type": "object" } },
    "effort_estimate": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "risk_mitigation_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "questions_for_user": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "alignment_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    }
  }
}
