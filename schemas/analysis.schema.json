{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Analysis Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "lineage_nodes",
    "lineage_edges",
    "macro_behavior_summary",
    "module_risk_scores",
    "migration_complexity_summary",
    "questions_for_user",
    "assumptions",
    "alignment_score"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "lineage_nodes": { "type": "array", "items": { "type": "object" } },
    "lineage_edges": { "type": "array", "items": { "type": "object" } },
    "macro_behavior_summary": {
      "type": "array",
      "items": { "type": "object" }
    },
    "module_risk_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "score"],
        "properties": {
          "module": { "type": "string" },
          "score": { "type": "integer", "minimum": 1, "maximum": 5 }
        }
      }
    },
    "migration_complexity_summary": { "type": "string" },
    "questions_for_user": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "alignment_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    }
  }
}
