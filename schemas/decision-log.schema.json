{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decision Log",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "entries"],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "decision", "rationale", "timestamp"],
        "properties": {
          "stage": {
            "type": "string",
            "enum": [
              "discover",
              "analyze",
              "plan",
              "design",
              "convert",
              "validate"
            ]
          },
          "decision": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
